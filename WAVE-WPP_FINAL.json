    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH s AS (SELECT public.safe_jsonb($1) AS obj) SELECT $2::text AS conversation_id, $3::text AS remote_jid, $4::text AS push_name, $5::text AS execution_id, $6::text AS owner_remote_jid, $7::timestamptz AS cutoff_ts, $8::text AS \"historyText\", $9::text AS user_text, (obj IS NOT NULL) AS is_valid, CASE WHEN obj ? 'lead_text' THEN obj->>'lead_text' ELSE 'Tive um problema rápido aqui. Pode repetir sua última mensagem em 1 linha?' END AS lead_text, CASE WHEN obj ? 'notify_owner' THEN (obj->>'notify_owner')::boolean ELSE true END AS notify_owner, CASE WHEN obj ? 'owner_summary' THEN obj->>'owner_summary' ELSE '⚠️ LLM retornou JSON inválido ou vazio. Verificar prompt/saída.' END AS owner_summary, CASE WHEN obj ? 'lead_score' THEN GREATEST(0, LEAST(100, (obj->>'lead_score')::int)) ELSE 100 END AS lead_score, encode(digest($2::text || '::owner::' || (CASE WHEN obj ? 'owner_summary' THEN obj->>'owner_summary' ELSE 'LLM_INVALID_JSON' END), 'sha256'),'hex') AS owner_hash FROM s;",
        "options": {
          "queryParameters": "={{ [ ($json.output || $json.response || $json.text || ''), $('Monta contexto (SQL)').first().json.conversation_id, $('Monta contexto (SQL)').first().json.remote_jid, $('Monta contexto (SQL)').first().json.push_name, $('Monta contexto (SQL)').first().json.execution_id, $('Monta contexto (SQL)').first().json.owner_remote_jid, $('Monta contexto (SQL)').first().json.cutoff_ts, ($('Monta contexto (SQL)').first().json.historyText || ''), ($('Monta contexto (SQL)').first().json.user_text || '') ] }}"
