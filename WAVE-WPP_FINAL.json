    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH base AS ( SELECT $1::text AS conversation_id, $2::timestamptz AS cutoff_ts, $3::text AS remote_jid, $4::text AS push_name, $5::text AS execution_id, $6::text AS owner_remote_jid, $7::text AS masked_phone, $8::text AS message_text ), inbound AS ( SELECT COALESCE(string_agg(im.message_text, E'\\n' ORDER BY im.created_at ASC), '') AS consolidated_text FROM base b LEFT JOIN public.inbound_messages im ON im.conversation_id = b.conversation_id AND im.created_at <= b.cutoff_ts ), mem AS ( SELECT COALESCE(string_agg(x.role || ': ' || x.content, E'\\n' ORDER BY x.created_at ASC), '') AS history_text FROM ( SELECT role, content, created_at FROM public.conversation_history WHERE conversation_id = $1 ORDER BY created_at DESC LIMIT 30 ) x ) SELECT b.conversation_id, b.remote_jid, b.push_name, b.execution_id, b.owner_remote_jid, b.cutoff_ts, m.history_text AS \"historyText\", CASE WHEN trim(i.consolidated_text) <> '' THEN left(i.consolidated_text, 6000) ELSE left(b.message_text, 6000) END AS user_text, encode(digest(b.conversation_id || '::' || CASE WHEN trim(i.consolidated_text) <> '' THEN left(i.consolidated_text, 6000) ELSE left(b.message_text, 6000) END, 'sha256'), 'hex') AS input_hash, b.masked_phone FROM base b CROSS JOIN inbound i CROSS JOIN mem m;",
        "options": {
          "queryParameters": "={{ [ $('Normaliza entrada').first().json.conversation_id, $('Checa última execução').first().json.last_message_at, $('Normaliza entrada').first().json.remoteJid, $('Normaliza entrada').first().json.pushName, $('Normaliza entrada').first().json.execution_id, $('Normaliza entrada').first().json.owner_remote_jid, $('Normaliza entrada').first().json.masked_phone, $('Normaliza entrada').first().json.messageText ] }}"
        }
