        "operation": "executeQuery",
        "query": "INSERT INTO public.inbound_messages (conversation_id, execution_id, message_id, message_text, push_name, remote_jid, created_at)\nVALUES ({{ $json.conversation_id }}, {{ $json.execution_id }}, {{ $json.messageId }}, {{ $json.messageText }}, {{ $json.pushName }}, {{ $json.remoteJid }}, NOW())\nON CONFLICT (conversation_id, message_id) DO NOTHING;\n\nINSERT INTO public.conversation_state (conversation_id, latest_execution_id, last_message_at, updated_at)\nVALUES ({{ $json.conversation_id }}, {{ $json.execution_id }}, NOW(), NOW())\nON CONFLICT (conversation_id)\nDO UPDATE SET latest_execution_id = EXCLUDED.latest_execution_id,\n              last_message_at = EXCLUDED.last_message_at,\n              updated_at = NOW();",
