    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\nconst conversation_id = $json.conversation_id;\nconst consolidated_text = String($json.consolidated_text || '').trim();\nconst input_hash = crypto.createHash('sha256').update(`${conversation_id}::${consolidated_text}`).digest('hex');\nconst masked = String($json.remote_jid || '').replace(/^(\\d{4})\\d+(\\@.*)$/,'$1****$2');\nreturn [{ json: { ...$json, consolidated_text, input_hash, masked_phone: masked } }];"
      },
