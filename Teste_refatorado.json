        "query": "SELECT conversation_id, push_name, remote_jid, string_agg(message_text, E'\\n' ORDER BY created_at ASC) AS consolidated_text\nFROM public.inbound_messages\nWHERE conversation_id = {{ $('Normaliza entrada').item.json.conversation_id }}\nGROUP BY conversation_id, push_name, remote_jid;",
